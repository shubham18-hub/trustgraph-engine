# TrustGraph Engine Environment Configuration

# =============================================================================
# AWS Configuration (for production deployment)
# =============================================================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=TrustGraph Engine
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=30

# =============================================================================
# Voice Processing Configuration
# =============================================================================
# Bhashini API (Government of India)
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_BASE_URL=https://bhashini.gov.in/api/v1

# AWS Transcribe/Polly (fallback)
AWS_TRANSCRIBE_REGION=ap-south-1
AWS_POLLY_REGION=ap-south-1

# Supported languages (ISO 639-1 codes)
SUPPORTED_LANGUAGES=hi,bn,te,mr,ta,gu,kn,ml,or,pa,as,ur,en

# =============================================================================
# Blockchain Configuration
# =============================================================================
# Hyperledger Fabric Network
FABRIC_NETWORK_NAME=trustgraph-network
FABRIC_CHANNEL_NAME=trustgraph-channel
FABRIC_CHAINCODE_NAME=trustledger
FABRIC_ORG_NAME=TrustGraphOrg
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_ORDERER_ENDPOINT=localhost:7050

# Credential Signing
CREDENTIAL_PRIVATE_KEY=your_ed25519_private_key
CREDENTIAL_PUBLIC_KEY=your_ed25519_public_key
DID_METHOD=did:india:

# =============================================================================
# Database Configuration
# =============================================================================
# Amazon Neptune (Graph Database)
NEPTUNE_ENDPOINT=your-neptune-cluster.cluster-xyz.ap-south-1.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_REGION=ap-south-1

# DynamoDB (NoSQL)
DYNAMODB_REGION=ap-south-1
DYNAMODB_TABLE_PREFIX=trustgraph-

# Redis (Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# =============================================================================
# Authentication Configuration
# =============================================================================
# Aadhaar Authentication (UIDAI)
UIDAI_AUA_CODE=your_aua_code
UIDAI_SUB_AUA_CODE=your_sub_aua_code
UIDAI_LICENSE_KEY=your_license_key
UIDAI_API_ENDPOINT=https://auth.uidai.gov.in/

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Voice Biometric
VOICE_BIOMETRIC_THRESHOLD=0.85
VOICE_SAMPLE_DURATION=3

# =============================================================================
# Payment Integration
# =============================================================================
# UPI Configuration (NPCI)
UPI_MERCHANT_ID=your_merchant_id
UPI_MERCHANT_KEY=your_merchant_key
UPI_API_ENDPOINT=https://api.npci.org.in/upi/

# Bank Integration
BANK_API_ENDPOINT=https://api.yourbank.com/
BANK_API_KEY=your_bank_api_key
BANK_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# Machine Learning Configuration
# =============================================================================
# SageMaker Configuration
SAGEMAKER_REGION=ap-south-1
SAGEMAKER_ROLE_ARN=arn:aws:iam::account:role/SageMakerRole
SAGEMAKER_INSTANCE_TYPE=ml.m5.large

# Graph Neural Network
GNN_MODEL_PATH=models/trustgraph_gnn.pkl
GNN_EMBEDDING_DIM=128
GNN_HIDDEN_LAYERS=3
GNN_LEARNING_RATE=0.001

# Trust Score Configuration
TRUST_SCORE_MIN=300
TRUST_SCORE_MAX=850
TRUST_SCORE_THRESHOLD=600

# =============================================================================
# Security Configuration
# =============================================================================
# Encryption
ENCRYPTION_KEY=your_32_byte_encryption_key_here
SALT=your_random_salt_here

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://trustgraph.gov.in
CORS_METHODS=GET,POST,PUT,DELETE
CORS_HEADERS=*

# =============================================================================
# Monitoring and Logging
# =============================================================================
# CloudWatch
CLOUDWATCH_LOG_GROUP=/aws/lambda/trustgraph
CLOUDWATCH_REGION=ap-south-1

# Application Insights
ENABLE_METRICS=true
METRICS_ENDPOINT=https://metrics.trustgraph.gov.in/

# Performance Monitoring
PERFORMANCE_THRESHOLD_MS=2000
ERROR_RATE_THRESHOLD=0.01

# =============================================================================
# Compliance Configuration
# =============================================================================
# DPDP Act 2023 Compliance
DATA_RETENTION_DAYS=2555  # 7 years
CONSENT_EXPIRY_DAYS=365
AUDIT_LOG_RETENTION_DAYS=3650  # 10 years

# Privacy Settings
ANONYMIZATION_ENABLED=true
PSEUDONYMIZATION_ENABLED=true
DATA_MINIMIZATION_ENABLED=true

# =============================================================================
# Development and Testing
# =============================================================================
# Test Configuration
TEST_DATABASE_URL=sqlite:///test_trustgraph.db
TEST_REDIS_DB=1
MOCK_EXTERNAL_APIS=true

# Development Tools
ENABLE_DEBUG_TOOLBAR=true
ENABLE_PROFILER=false
RELOAD_ON_CHANGE=true

# Sample Data
LOAD_SAMPLE_DATA=true
SAMPLE_WORKERS_COUNT=1000
SAMPLE_EMPLOYERS_COUNT=100

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_VOICE_PROCESSING=true
ENABLE_BLOCKCHAIN=true
ENABLE_ML_SCORING=true
ENABLE_UPI_PAYMENTS=true
ENABLE_AADHAAR_AUTH=false  # Set to false for local testing
ENABLE_REAL_BANKING=false  # Set to false for local testing

# =============================================================================
# Local Development Overrides
# =============================================================================
# Use local services instead of AWS for development
USE_LOCAL_REDIS=true
USE_LOCAL_DATABASE=true
USE_MOCK_VOICE_API=true
USE_MOCK_BLOCKCHAIN=true
USE_MOCK_PAYMENTS=true

# Local file paths
LOCAL_MODEL_PATH=./models/
LOCAL_AUDIO_PATH=./audio_samples/
LOCAL_LOGS_PATH=./logs/