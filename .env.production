# TrustGraph Engine - Production Environment Configuration
# DO NOT commit this file with real credentials

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id

# Database
DATABASE_PATH=/app/data/trustgraph.db
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_INTERVAL=3600

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=30
API_MAX_REQUESTS=1000

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
ENCRYPTION_KEY=your-32-byte-encryption-key-change-this

# AWS Services
BEDROCK_MODEL_ID=anthropic.claude-v2
BEDROCK_REGION=ap-south-1
S3_BUCKET_NAME=trustgraph-credentials-production
KMS_KEY_ID=your-kms-key-id

# DynamoDB Tables
DYNAMODB_USERS_TABLE=trustgraph-users-production
DYNAMODB_CREDENTIALS_TABLE=trustgraph-credentials-production
DYNAMODB_TRANSACTIONS_TABLE=trustgraph-transactions-production

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=trustgraph2024
REDIS_DB=0
REDIS_CACHE_TTL=3600

# Voice Service (Bhashini)
BHASHINI_API_KEY=your-bhashini-api-key
BHASHINI_USER_ID=your-bhashini-user-id
BHASHINI_PIPELINE_ID=your-pipeline-id

# UPI Integration
UPI_MERCHANT_ID=your-merchant-id
UPI_MERCHANT_KEY=your-merchant-key
UPI_CALLBACK_URL=https://api.trustgraph.gov.in/api/upi/callback

# Aadhaar Integration
AADHAAR_API_KEY=your-aadhaar-api-key
AADHAAR_AGENCY_ID=your-agency-id
AADHAAR_LICENSE_KEY=your-license-key

# Monitoring & Logging
CLOUDWATCH_LOG_GROUP=/aws/trustgraph/production
CLOUDWATCH_LOG_STREAM=application
SENTRY_DSN=your-sentry-dsn
METRICS_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS Configuration
CORS_ORIGINS=https://trustgraph.gov.in,https://www.trustgraph.gov.in
CORS_ALLOW_CREDENTIALS=true

# Feature Flags
VOICE_INTERFACE_ENABLED=true
BLOCKCHAIN_ENABLED=true
ML_PREDICTIONS_ENABLED=true
AGENTIC_CONTRACTS_ENABLED=true

# Compliance
DPDP_COMPLIANCE_MODE=strict
DATA_RESIDENCY_REGION=ap-south-1
AUDIT_LOGGING_ENABLED=true
